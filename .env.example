# Copy this file to `.env` (which is gitignored and never leaves your machine) and fill in the values.

# Notesnook Inbox API key.
# Get it in Notesnook: Settings -> Inbox -> Enable Inbox API -> create an API key -> paste here.
NOTESNOOK_INBOX_API_KEY=

# Asana personal access token.
# Create one in the Asana developer console: https://app.asana.com/0/my-apps
# (Create new token, name it anything, copy it here). Needed only to submit memos to Asana.
ASANA_ACCESS_TOKEN=

# A second Asana account is a second token, under a name you pick. Sign in as that
# account first, then make its token the same way. The name is yours — WORK below is
# only an example — and it is what a parent task is marked with to say it lives there.
# ASANA_ACCESS_TOKEN_WORK=

# The Asana tasks a memo can become a subtask of: "task_gid=Label" pairs separated by ";".
# The gid is the long number in the task's URL; the label is what the inbox dropdown shows.
# The first pair is the default. Prefix a gid with "NAME:" to say it belongs to the
# account whose token is ASANA_ACCESS_TOKEN_NAME — both accounts' tasks are one list,
# and the inbox never asks which is which. Example:
# ASANA_PARENT_TASKS=1200000000000001=Song ideas;WORK:1200000000000002=Work backlog
ASANA_PARENT_TASKS=

# The directory a note routed to Claude's "Code" opens its session in. A voice note has
# no project of its own, so this is only where it starts you — change the directory in
# Claude's own UI once the session is open. Defaults to this checkout. Claude asks once
# per directory whether you trust it, and it remembers the path exactly as written: on
# Windows use backslashes, or the same folder spelled with "/" is asked about again.
HIGHDEAS_CLAUDE_FOLDER=

# The models the "Chat" dropdown offers: "model_id=Label" pairs separated by ";", first
# one the default. The id is what claude.ai takes in a link (claude-sonnet-5), not the
# name on the picker. Setting this REPLACES the built-in list rather than adding to it —
# which is the point, since models come and go faster than this app is edited. Only a
# chat can be opened on a chosen model; the Code link carries no model, and neither
# carries an effort level. Example:
# HIGHDEAS_CLAUDE_MODELS=claude-opus-4-8=Opus 4.8;claude-sonnet-5=Sonnet 5
HIGHDEAS_CLAUDE_MODELS=

# Folder where the iOS Shortcut drops new recordings, mirrored to this PC by iCloud for Windows.
# NOTE: Explorer shows this as ...\iCloudDrive\Shortcuts\Highdeas, but on disk the Shortcuts
# app's folder is named after its container id (iCloud~is~workflow~my~workflows).
HIGHDEAS_INBOX_DIR=C:\Users\Douglas\iCloudDrive\iCloud~is~workflow~my~workflows\Highdeas

# Google Drive "voice memos (top level)" folder (mirrored to this PC by Drive for Desktop).
# Music-routed memos are moved into a dated subfolder here.
HIGHDEAS_DRIVE_BASE=G:\My Drive\voice memos (top level)

# Direct link to that same Drive folder, for the bin's Drive icon to open. Get it from
# Drive itself: open the folder at drive.google.com, then Share -> Copy link. Without
# this, the Drive icon does nothing. With it but no service account below, the icon
# opens this top-level folder for every memo, regardless of which one you clicked.
HIGHDEAS_DRIVE_FOLDER_URL=

# Path to a Google Cloud service account JSON key file, so the bin's Drive icon can look
# up and open the actual dated subfolder a memo's audio was filed into, instead of always
# this same top-level folder. Optional -- see README "Google Drive per-memo folder links"
# for how to create one. Requires HIGHDEAS_DRIVE_FOLDER_URL above to be set too -- this
# searches inside that same folder -- and that folder must be shared with the service
# account's own email address, or the lookup finds nothing and the icon falls back to the
# top-level link. Leave blank to skip this and always use the top-level link.
HIGHDEAS_GOOGLE_SERVICE_ACCOUNT_FILE=

# Path to the token file scripts/authorize_google_docs.py writes after Douglas signs
# in once, so the bin's Google Drive route can file a memo's transcript as a real,
# native Google Doc through the actual Drive API -- not the .docx-into-a-synced-folder
# trick -- instead of it, not beside it. Optional -- see README "Google Drive native
# Doc filing" for the one-time setup. Leave blank to keep writing a local .docx like
# before.
HIGHDEAS_GOOGLE_DOCS_TOKEN_FILE=

# The Drive folder (at Drive's own top level, not inside HIGHDEAS_DRIVE_BASE -- see
# README) that native Google Docs are filed into, in a dated subfolder per day like
# HIGHDEAS_DRIVE_BASE already uses. Only read when HIGHDEAS_GOOGLE_DOCS_TOKEN_FILE
# above is set. Defaults to "Highdeas Voice Memo Docs" when blank.
HIGHDEAS_DRIVE_DOCS_FOLDER_NAME=

# Shared secret the iOS capture app presents to push recordings to POST /upload.
# Any long random string (e.g. `openssl rand -hex 32`); enter the same value in the
# phone's settings screen. While this is empty the upload listener never starts.
HIGHDEAS_UPLOAD_TOKEN=

# LAN port the upload listener binds (on 0.0.0.0 — reachable from the phone). Only
# /upload lives there; the inbox UI stays loopback-only. Allow this port through
# Windows Firewall once (see README).
HIGHDEAS_UPLOAD_PORT=5055

# Your own vocabulary: the names and terms the speech model has never heard
# ("Highdeas", "Sagittal", the people in your life), one per line, so transcripts stop
# mangling them. A gloss may follow the term after " — " or ": ", and "#" lines are
# comments — the term is the head of the line. Defaults to lexicon.md beside
# HIGHDEAS_STATE_DIR (one list, both machines), or in this folder when Highdeas runs
# alone. No file, no corrections.
HIGHDEAS_LEXICON=

# Google Sheets whose columns of names join that lexicon are listed in
# lexicon-sources.md beside it, one line each (a link, then the cells) — not here, since
# there will be many of them and a list is not a setting. This is only the key that
# reads them all: Google Cloud console -> IAM -> Service accounts -> Keys -> JSON, with
# each sheet shared with that account's email as Viewer. Defaults to google-key.json
# beside the lexicon. Treat the file as a password.
HIGHDEAS_GOOGLE_KEY=

# The no-special-machine switch. Point this at the state folder a sync engine
# (Syncthing) shares between your machines, and memo state lives there as one
# JSON file per memo — any memos in the local HIGHDEAS_DB are carried across on
# first boot, and the DB is never read again. Leave unset to keep single-machine
# SQLite. See docs/mac-peer.md.
HIGHDEAS_STATE_DIR=
