# Secrets — never commit
.env

# Your own vocabulary for transcription — names and terms, some of them people's —
# with the key that reads the names sheet and the names last read from it
/lexicon.md
/lexicon-sources.md
/google-key.json
/sheet-names.json

# Google Cloud service-account key (README: "Google Drive per-memo folder links" says to
# save this outside the repo, but this backstops that in case it ever lands in here anyway)
highdeas-drive-reader.json
*.serviceaccount.json

# Local database, the processed-audio bin, and the remembered window geometry
memos.db
bin/
window.json

# Generated, machine-specific taskbar shortcut (rebuild with "Create Highdeas Shortcut.bat")
/Highdeas.lnk

# Claude Code worktrees and local settings
.claude/

# Xcode / Swift build products and per-user state (ios/)
xcuserdata/
ios/**/.build/
ios/**/DerivedData/

# Xcode / SwiftPM build artifacts
ios/HighdeasKit/.build/
ios/build/
*.xcuserdatad/
